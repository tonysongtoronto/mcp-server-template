{
    "version": "2.0.0",
    "tasks": [
        {
            // ✅ 你原来的，保持不动
            "label": "wait-for-server",
            "type": "shell",
            "command": "powershell",
            "args": ["-Command", "Start-Sleep -Seconds 20"],
            "presentation": {
                "reveal": "silent",
                "clear": true
            },
            "problemMatcher": []
        },

        // ✅ 在下面加一个逗号，然后加这两个新的
        {
            "label": "🖥️ 切换到：本地调试模式",
            "type": "shell",
            "command": "powershell",
            "args": ["-Command", "Copy-Item .vscode/launch.local.json .vscode/launch.json"],
            "presentation": { "reveal": "silent", "close": true },
            "problemMatcher": []
        },
        {
            "label": "🐳 切换到：Docker 模式",
            "type": "shell",
            "command": "powershell",
            "args": ["-Command", "Copy-Item .vscode/launch.docker.json .vscode/launch.json"],
            "presentation": { "reveal": "silent", "close": true },
            "problemMatcher": []
        }
    ]
}